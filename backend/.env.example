PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sqli_sentinel?retryWrites=true&w=majority
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=10000

# MongoDB Atlas note:
# Add 0.0.0.0/0 (or your current client IP) in Atlas Network Access,
# otherwise the connection can fail when your IP changes.
